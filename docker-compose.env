# CORE stack configuration.
#
# docker-compose reads this file via `--env-file docker-compose.env` (or copy it
# to `.env`). CHANGE EVERY PASSWORD AND KEY BELOW before any real deployment.
# Avoid the characters ' " \ / $ in passwords to keep YAML/shell parsing simple.

## Versions
# Pin to a specific release for reproducible builds. Kibana and Logstash use the same tag.
ELASTICSEARCH_VERSION='8.15.3'

## Cluster connection (used by the setup container)
ELASTICSEARCH_HOST='es01'
ELASTICSEARCH_PORT='9200'

## Credentials  --  CHANGE THESE
# Superuser for the cluster. Bootstrapped on first start of the es0x nodes.
ELASTIC_PASSWORD='changeme-elastic'
# Built-in account Kibana uses to talk to Elasticsearch (set by the setup container).
KIBANA_PASSWORD='changeme-kibana'
# Least-privilege account Logstash uses to write logstash-* indices.
LOGSTASH_PASSWORD='changeme-logstash'

# Kibana saved-object / session encryption. Must be at least 32 characters.
# Generate one with:  openssl rand -hex 16
KIBANA_ENCRYPTION_KEY='change-me-to-a-random-32char-string!'

## Certificate validity (days) for the generated CA and node certificates.
CERT_DAYS='730'
